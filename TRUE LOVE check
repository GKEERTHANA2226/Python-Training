# TRUE LOVE check
mine = input()
yours = input()
name = mine + yours
name.lower()
t = name.count('t')
r = name.count('r')
u = name.count('u')
e = name.count('e')
true = t+r+u+e
l = name.count('l')
o = name.count('o')
v = name.count('v')
e = name.count('e')
love = l+o+v+e
love_score = int(str(true)+str(love))

if love_score > 70:
  print(f"your love score is {love_score}, you are made for each other")
elif love_score > 40:
  print(f"your love score is {love_score}, you are alright")
else:
  print(f"your love score is {love_score}")
